# Database connection details
DATABASE_URL=postgres://user:password@host:5432/mydatabase

# API Keys
API_KEY=your_api_key_here

# JWT secret
JWT_SECRET=your_jwt_secret_here

# Port (Render lo asigna automáticamente, no lo fijes tú)
# PORT=3000   ← ⚠️ No lo pongas, Render ya lo inyecta

# Other configuration settings
OTHER_SETTING=some_value
